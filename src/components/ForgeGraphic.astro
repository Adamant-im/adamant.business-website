---
// Decorative blueprint-style illustration: a crucible casting molten metal
// into a stack of hexagonal blocks. Purely presentational.
---

<svg
  viewBox="0 0 440 460"
  fill="none"
  aria-hidden="true"
  class="h-auto w-full max-w-md select-none"
>
  <defs>
    <linearGradient id="fg-ember" x1="0" y1="0" x2="0.3" y2="1">
      <stop offset="0" stop-color="#ffb45c"></stop>
      <stop offset="0.6" stop-color="#f07316"></stop>
      <stop offset="1" stop-color="#d1540e"></stop>
    </linearGradient>
    <linearGradient id="fg-stream" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#ffb45c"></stop>
      <stop offset="1" stop-color="#f07316"></stop>
    </linearGradient>
    <clipPath id="fg-hex-top">
      <path d="M294 200 272 238.1 228 238.1 206 200 228 161.9 272 161.9Z"></path>
    </clipPath>
  </defs>

  <!-- blueprint guides -->
  <g stroke="#1d1712" stroke-opacity="0.18" stroke-width="1" stroke-dasharray="4 6">
    <circle cx="132" cy="86" r="64"></circle>
    <path d="M250 20v120M250 258v40M120 200h86M294 200h110"></path>
  </g>
  <g stroke="#1d1712" stroke-opacity="0.35" stroke-width="1.5">
    <path d="M20 20h16M20 20v16M420 440h-16M420 440v-16"></path>
  </g>

  <!-- crosshair at cast point -->
  <g stroke="#b8430c" stroke-opacity="0.5" stroke-width="1.2">
    <path d="M250 188v24M238 200h24"></path>
  </g>

  <!-- crucible -->
  <g transform="rotate(34 132 86)">
    <path d="M96 62 168 62 154 118 110 118Z" fill="#211b14" stroke="#3a2f22" stroke-width="2" stroke-linejoin="round"></path>
    <path d="M90 58 174 58 168 70 96 70Z" fill="#2c241a" stroke="#3a2f22" stroke-width="2" stroke-linejoin="round"></path>
    <path d="M104 64 160 64" stroke="url(#fg-ember)" stroke-width="5" stroke-linecap="round"></path>
  </g>

  <!-- molten stream -->
  <path
    d="M172 118 C 214 140, 242 158, 249 196"
    stroke="url(#fg-stream)"
    stroke-width="7"
    stroke-linecap="round"></path>

  <!-- sparks -->
  <g fill="#f07316">
    <path d="M280 150l4 4-4 4-4-4Z"></path>
    <path d="M215 172l3.2 3.2-3.2 3.2-3.2-3.2Z" opacity="0.75"></path>
    <path d="M300 205l3 3-3 3-3-3Z" opacity="0.6"></path>
    <path d="M196 220l2.6 2.6-2.6 2.6-2.6-2.6Z" opacity="0.5"></path>
  </g>

  <!-- top hex: being cast, half-filled with molten metal -->
  <g>
    <g clip-path="url(#fg-hex-top)">
      <rect x="200" y="204" width="100" height="40" fill="url(#fg-ember)"></rect>
      <path d="M206 204h88" stroke="#ffc061" stroke-width="2.5"></path>
    </g>
    <path
      d="M294 200 272 238.1 228 238.1 206 200 228 161.9 272 161.9Z"
      stroke="#1d1712"
      stroke-width="2.5"
      stroke-linejoin="round"></path>
  </g>

  <!-- middle hex: cooled casting -->
  <path
    d="M294 276.2 272 314.3 228 314.3 206 276.2 228 238.1 272 238.1Z"
    fill="#211b14"
    stroke="#3a2f22"
    stroke-width="2"
    stroke-linejoin="round"></path>
  <text x="250" y="281" text-anchor="middle" font-family="ui-monospace, Menlo, monospace" font-size="12" fill="#a89c8c">0x02</text>

  <!-- bottom hex -->
  <path
    d="M294 352.4 272 390.5 228 390.5 206 352.4 228 314.3 272 314.3Z"
    fill="#211b14"
    stroke="#3a2f22"
    stroke-width="2"
    stroke-linejoin="round"></path>
  <text x="250" y="357" text-anchor="middle" font-family="ui-monospace, Menlo, monospace" font-size="12" fill="#a89c8c">0x01</text>

  <!-- side hexes: outline only, future blocks -->
  <path
    d="M228 314.3 206 352.4 162 352.4 140 314.3 162 276.2 206 276.2Z"
    stroke="#1d1712"
    stroke-opacity="0.3"
    stroke-width="1.6"
    stroke-linejoin="round"
    stroke-dasharray="5 5"></path>
  <path
    d="M382 314.3 360 352.4 316 352.4 294 314.3 316 276.2 360 276.2Z"
    stroke="#1d1712"
    stroke-opacity="0.3"
    stroke-width="1.6"
    stroke-linejoin="round"
    stroke-dasharray="5 5"></path>

  <!-- baseline -->
  <path d="M120 392.5h260" stroke="#1d1712" stroke-opacity="0.4" stroke-width="2"></path>
  <path d="M132 402 126 410M156 402l-6 8M180 402l-6 8M204 402l-6 8M228 402l-6 8M252 402l-6 8M276 402l-6 8M300 402l-6 8" stroke="#1d1712" stroke-opacity="0.25" stroke-width="1.4"></path>

  <!-- annotations -->
  <text x="330" y="120" font-family="ui-monospace, Menlo, monospace" font-size="11" letter-spacing="2" fill="#6b6156">MELT</text>
  <text x="330" y="200" font-family="ui-monospace, Menlo, monospace" font-size="11" letter-spacing="2" fill="#b8430c">CAST</text>
  <text x="330" y="420" font-family="ui-monospace, Menlo, monospace" font-size="11" letter-spacing="2" fill="#6b6156">RUN</text>
</svg>
