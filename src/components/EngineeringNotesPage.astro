---
import BaseLayout from '../layouts/BaseLayout.astro';
import NotesGrid from './react/NotesGrid';
import { getLocaleConfig, getUiStrings, type LocaleId } from '../i18n';
import {
  getNotesForLocale,
  getNotesPage,
  getNotesPageCount,
  noteIndexPath,
  toNoteCard,
} from '../lib/notes';

interface Props {
  locale: LocaleId;
  page: number;
}

const { locale, page } = Astro.props;
const ui = getUiStrings(locale);
const localeConfig = getLocaleConfig(locale);
const entries = await getNotesForLocale(locale);
const pageCount = getNotesPageCount(entries);
if (page < 1 || page > pageCount) throw new Error(`Invalid engineering notes page: ${page}`);
const notes = getNotesPage(entries, page).map((entry) => toNoteCard(entry, locale));
const canonicalPath = noteIndexPath(locale, page);
const previousPath = page > 1 ? noteIndexPath(locale, page - 1) : undefined;
const nextPath = page < pageCount ? noteIndexPath(locale, page + 1) : undefined;
const labels = {
  article: ui.engineeringNotes.article,
  release: ui.engineeringNotes.release,
  released: ui.engineeringNotes.released,
  discussion: ui.engineeringNotes.discussion,
  github: ui.engineeringNotes.github,
};
---

<BaseLayout
  title={ui.engineeringNotes.title}
  description={ui.engineeringNotes.intro}
  locale={locale}
  canonicalPath={canonicalPath}
  prevPath={previousPath}
  nextPath={nextPath}
>
  <section class="section-light grid-texture border-b border-border">
    <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6 sm:py-20">
      <p class="eyebrow">{ui.engineeringNotes.eyebrow}</p>
      <h1 class="mt-3 max-w-3xl text-4xl font-semibold tracking-tight text-text sm:text-5xl">
        {ui.engineeringNotes.title}
      </h1>
      <p class="mt-5 max-w-3xl text-lg leading-relaxed text-muted">{ui.engineeringNotes.intro}</p>
    </div>
  </section>

  <section class="section-light">
    <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 sm:py-14">
      {notes.length > 0 ? (
        <NotesGrid notes={notes} localeCode={localeConfig.codes[0]} labels={labels} />
      ) : (
        <p class="text-muted">{ui.engineeringNotes.empty}</p>
      )}

      <nav class="mt-12 flex items-center justify-between border-t border-border pt-6" aria-label="Pagination">
        <div>
          {previousPath && <a class="btn-secondary" href={previousPath}>← {ui.engineeringNotes.previous}</a>}
        </div>
        <div>
          {nextPath && <a class="btn-secondary" href={nextPath}>{ui.engineeringNotes.next} →</a>}
        </div>
      </nav>
    </div>
  </section>
</BaseLayout>
