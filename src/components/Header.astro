---
import { siteConfig } from '../../config/site.ts';
import ContactModal from './react/ContactModal';
import LanguagePrompt from './react/LanguagePrompt';
import LanguageSwitcher from './react/LanguageSwitcher';
import Logo from './Logo.astro';
import { getUiStrings, localePath, stripLocalePrefix, type LocaleId } from '../i18n';

interface Props {
  locale: LocaleId;
}

const { locale } = Astro.props;
const ui = getUiStrings(locale);
const { path: currentPath } = stripLocalePrefix(Astro.url.pathname);
const year = new Date().getFullYear();
const { site } = siteConfig;
const homeHref = localePath(locale, '/');
---

<header class="sticky top-0 z-50 border-b border-border/80 bg-bg/90 backdrop-blur-md">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3 sm:px-6">
    <div class="flex min-w-0 items-center gap-4">
      <a
        href={homeHref}
        class="flex items-center gap-2.5 text-lg font-semibold tracking-tight text-text no-underline hover:no-underline"
      >
        <Logo size={30} class="shrink-0" />
        <span class="truncate">{site.name}</span>
      </a>
      <span class="hidden font-mono text-[0.68rem] tracking-widest text-muted md:inline">
        {site.foundedYear}–{year}
      </span>
    </div>

    <div class="relative flex items-center gap-2 sm:gap-3">
      <LanguageSwitcher client:load locale={locale} label={ui.language.switcherLabel} currentPath={currentPath} />
      <LanguagePrompt
        client:load
        locale={locale}
        keepEnglish={ui.language.keepEnglish}
        promptPrefix={ui.language.promptPrefix}
      />
      <ContactModal client:load variant="header" label={ui.header.contact} strings={ui.contact} openFromHash />
    </div>
  </div>
  <div class="heat-line"></div>
</header>
