---
import {
  getHreflangAlternates,
  getLocaleConfig,
  getOgLocale,
  stripLocalePrefix,
  type LocaleId,
} from '../i18n';

interface Props {
  title: string;
  description: string;
  locale: LocaleId;
  canonicalPath?: string;
  ogType?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  noindex?: boolean;
}

const {
  title,
  description,
  locale,
  canonicalPath = Astro.url.pathname,
  ogType = 'website',
  jsonLd,
  noindex = false,
} = Astro.props;

const { site, seo } = await import('../../config/site.ts').then((m) => m.siteConfig);
const localeConfig = getLocaleConfig(locale);
const canonicalUrl = new URL(canonicalPath, site.url).href;
const ogImage = new URL(seo.defaultOgImage, site.url).href;
const fullTitle = title === site.name ? title : `${title} — ${site.name}`;
const { path: pathWithoutLocale } = stripLocalePrefix(canonicalPath);
const hreflangAlternates = getHreflangAlternates(pathWithoutLocale);
const ogLocale = getOgLocale(locale);
const alternateOgLocales = hreflangAlternates
  .filter((item) => item.hreflang !== 'x-default' && !item.hreflang.includes('-'))
  .map((item) => getOgLocale(item.hreflang as LocaleId))
  .filter((code) => code !== ogLocale);

const baseOrganization = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: site.legalName,
  url: site.url,
  foundingDate: String(site.foundedYear),
  description: site.positioning,
  knowsAbout: [
    'self-hosted crypto software',
    'blockchain infrastructure',
    'trading bots',
    'crypto payments',
    'security audits',
    'encrypted messaging',
  ],
  sameAs: seo.sameAs,
};

const baseWebsite = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: site.name,
  url: site.url,
  description: site.heroTagline,
  inLanguage: localeConfig.codes[0],
  publisher: { '@type': 'Organization', name: site.legalName },
};

const jsonLdGraph = jsonLd
  ? Array.isArray(jsonLd)
    ? [baseOrganization, baseWebsite, ...jsonLd]
    : [baseOrganization, baseWebsite, jsonLd]
  : [baseOrganization, baseWebsite];
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />
{noindex && <meta name="robots" content="noindex, nofollow" />}
{
  hreflangAlternates.map((alternate) => (
    <link rel="alternate" hreflang={alternate.hreflang} href={alternate.href} />
  ))
}

<meta property="og:type" content={ogType} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:site_name" content={site.name} />
<meta property="og:locale" content={ogLocale} />
{alternateOgLocales.map((code) => <meta property="og:locale:alternate" content={code} />)}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content={seo.twitterHandle} />
<meta name="twitter:creator" content={seo.twitterHandle} />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" type="image/x-icon" sizes="48x48" href="/favicon.ico" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<meta name="theme-color" content="#16120d" />

<script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLdGraph)} />
