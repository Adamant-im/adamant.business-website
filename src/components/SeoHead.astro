---
import {
  getHreflangAlternates,
  getLocaleConfig,
  getOgLocale,
  getUiStrings,
  stripLocalePrefix,
  type LocaleId,
} from '../i18n';

interface Props {
  title: string;
  description: string;
  locale: LocaleId;
  canonicalPath?: string;
  ogType?: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  pageType?: 'WebPage' | 'CollectionPage';
  prevPath?: string;
  nextPath?: string;
}

const {
  title,
  description,
  locale,
  canonicalPath = Astro.url.pathname,
  ogType = 'website',
  ogImage,
  jsonLd,
  pageType = 'WebPage',
  prevPath,
  nextPath,
} = Astro.props;

const { site, contact, locales, seo } = await import('../../config/site.ts').then((m) => m.siteConfig);
const localeConfig = getLocaleConfig(locale);
const ui = getUiStrings(locale);
const canonicalUrl = new URL(canonicalPath, site.url).href;
const ogImageUrl = new URL(ogImage || seo.defaultOgImage, site.url).href;
const fullTitle = title === site.name ? title : `${title} — ${site.name}`;
const { path: pathWithoutLocale } = stripLocalePrefix(canonicalPath);
const hreflangAlternates = getHreflangAlternates(pathWithoutLocale);
const ogLocale = getOgLocale(locale);
const alternateOgLocales = hreflangAlternates
  .filter((item) => item.hreflang !== 'x-default' && !item.hreflang.includes('-'))
  .map((item) => getOgLocale(item.hreflang as LocaleId))
  .filter((code) => code !== ogLocale);

const organizationId = new URL('/#organization', site.url).href;
const websiteId = new URL('/#website', site.url).href;
const webpageId = `${canonicalUrl}#webpage`;

const baseOrganization = {
  '@type': 'Organization',
  '@id': organizationId,
  name: site.legalName,
  url: site.url,
  logo: new URL('/apple-touch-icon.png', site.url).href,
  email: `mailto:${contact.email}`,
  description: ui.meta.homeDescription,
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'sales',
    email: contact.email,
    url: new URL('/#contact', site.url).href,
    availableLanguage: locales.map((item) => item.codes[0]),
  },
  knowsAbout: [
    'self-hosted crypto software',
    'blockchain infrastructure',
    'trading bots',
    'crypto payments',
    'security audits',
    'encrypted messaging',
  ],
};

const baseWebsite = {
  '@type': 'WebSite',
  '@id': websiteId,
  name: site.name,
  url: site.url,
  description: ui.meta.homeDescription,
  inLanguage: localeConfig.codes[0],
  publisher: { '@id': organizationId },
};

const baseWebpage = {
  '@type': pageType,
  '@id': webpageId,
  url: canonicalUrl,
  name: fullTitle,
  description,
  inLanguage: localeConfig.codes[0],
  isPartOf: { '@id': websiteId },
  about: { '@id': organizationId },
  ...(ogImage ? { primaryImageOfPage: { '@type': 'ImageObject', url: ogImageUrl } } : {}),
};

const pageJsonLd = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const jsonLdGraph = {
  '@context': 'https://schema.org',
  '@graph': [baseOrganization, baseWebsite, baseWebpage, ...pageJsonLd],
};
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<title>{fullTitle}</title>
<meta name="description" content={description} />
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
<link rel="canonical" href={canonicalUrl} />
{prevPath && <link rel="prev" href={new URL(prevPath, site.url).href} />}
{nextPath && <link rel="next" href={new URL(nextPath, site.url).href} />}
{
  hreflangAlternates.map((alternate) => (
    <link rel="alternate" hreflang={alternate.hreflang} href={alternate.href} />
  ))
}

<meta property="og:type" content={ogType} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:alt" content={fullTitle} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:site_name" content={site.name} />
<meta property="og:locale" content={ogLocale} />
{alternateOgLocales.map((code) => <meta property="og:locale:alternate" content={code} />)}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />
<meta name="twitter:image:alt" content={fullTitle} />

<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" type="image/x-icon" sizes="48x48" href="/favicon.ico" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<meta name="theme-color" content="#16120d" />

<script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLdGraph)} />
