---
import { getEntry } from 'astro:content';
import { siteConfig } from '../../config/site.ts';
import Logo from './Logo.astro';
import { formatTemplate, getUiStrings, localePath, type LocaleId } from '../i18n';

interface Props {
  locale: LocaleId;
}

const { locale } = Astro.props;
const ui = getUiStrings(locale);
const { site, contact, seo } = siteConfig;
const githubUrl = seo.sameAs.find((url) => url.includes('github.com'));

const serviceEntries = await Promise.all(
  siteConfig.services.map(async (service) => {
    const entry = await getEntry('services', `${locale}/${service.slug}`);
    return entry ?? (await getEntry('services', `en/${service.slug}`));
  }),
);
---

<footer class="section-dark border-t border-dark-border">
  <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
    <div class="grid gap-10 md:grid-cols-[1.4fr_1fr_1fr]">
      <div>
        <div class="flex items-center gap-2.5">
          <Logo size={32} />
          <span class="text-lg font-semibold tracking-tight text-white">{site.name}</span>
        </div>
        <p class="mt-4 max-w-sm text-sm leading-relaxed">
          {formatTemplate(ui.footer.tagline, { year: site.foundedYear })}
        </p>
        <p class="mt-4 font-mono text-xs tracking-widest text-dark-muted">
          {site.domain}
        </p>
      </div>

      <nav aria-label={ui.footer.services}>
        <h2 class="eyebrow">{ui.footer.services}</h2>
        <ul class="mt-4 space-y-2.5 text-sm">
          {
            serviceEntries.map((entry) => {
              if (!entry) return null;
              const slug = entry.id.replace(/^[^/]+\//, '').replace(/\.md$/, '');
              return (
                <li>
                  <a
                    href={localePath(locale, `/${slug}`)}
                    class="text-dark-muted no-underline hover:text-white hover:no-underline"
                  >
                    {entry.data.title}
                  </a>
                </li>
              );
            })
          }
        </ul>
      </nav>

      <div>
        <h2 class="eyebrow">{ui.footer.contact}</h2>
        <ul class="mt-4 space-y-2.5 text-sm">
          <li>
            <a href={`mailto:${contact.email}`} class="text-dark-muted no-underline hover:text-white hover:no-underline">
              {contact.email}
            </a>
          </li>
          <li>
            <a href={contact.telegramUrl} class="text-dark-muted no-underline hover:text-white hover:no-underline">
              {ui.footer.telegramPrefix} {contact.telegram}
            </a>
          </li>
          <li>
            <a href={contact.adamantMessenger} class="text-dark-muted no-underline hover:text-white hover:no-underline">
              {ui.footer.adamant}
            </a>
          </li>
          {
            githubUrl && (
              <li>
                <a href={githubUrl} class="text-dark-muted no-underline hover:text-white hover:no-underline">
                  {ui.footer.github}
                </a>
              </li>
            )
          }
        </ul>
      </div>
    </div>

    <div class="mt-12 flex flex-wrap items-center gap-x-5 gap-y-3 border-t border-dark-border pt-6">
      <p class="font-mono text-[0.68rem] tracking-widest text-dark-muted">{ui.footer.motto}</p>
      <a
        href={localePath(locale, '/engineering-notes')}
        class="ms-3 inline-flex items-center gap-2 bg-ember px-3 font-mono text-[0.68rem] font-semibold uppercase tracking-widest text-dark-bg no-underline transition hover:bg-ember-bright hover:text-dark-bg hover:no-underline"
      >
        <span aria-hidden="true">&gt;</span>
        {ui.engineeringNotes.eyebrow}
      </a>
    </div>
  </div>
</footer>
