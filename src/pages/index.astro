---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactModal from '../components/react/ContactModal';
import RepoCarousel from '../components/react/RepoCarousel';
import ForgeGraphic from '../components/ForgeGraphic.astro';
import ServiceIcon from '../components/ServiceIcon.astro';
import { siteConfig } from '../../config/site.ts';
import reposData from '../data/repos.json';

const { site, services, faq } = siteConfig;
const yearsRunning = new Date().getFullYear() - site.foundedYear;
const repoCount = reposData.length;

const faqJsonLd = {
  '@type': 'FAQPage',
  mainEntity: faq.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};

const homeDescription =
  'cryptofoundry builds and maintains self-hosted crypto automation and infrastructure for teams that want control, security, and real engineering.';

const process = [
  {
    step: '01',
    title: 'Scope',
    text: 'You describe the workflow, exchanges, chains, and constraints. We answer with a concrete technical proposal — components, boundaries, and what we will not build.',
  },
  {
    step: '02',
    title: 'Forge',
    text: 'We build in short iterations on a repository you can read. Working software early, no black boxes, no surprise rewrites at the end.',
  },
  {
    step: '03',
    title: 'Temper',
    text: 'Security review, key handling, monitoring, and failure drills before anything touches real funds or production traffic.',
  },
  {
    step: '04',
    title: 'Run',
    text: 'Deployment on your infrastructure, documentation, and long-term maintenance if you want it. You keep the keys and the off switch.',
  },
];
---

<BaseLayout
  title={site.name}
  description={homeDescription}
  jsonLd={faqJsonLd}
>
  <section class="section-light grid-texture border-b border-border">
    <div class="mx-auto max-w-6xl px-4 pt-16 pb-10 sm:px-6 sm:pt-20">
      <div class="grid items-center gap-12 lg:grid-cols-[1.15fr_0.85fr]">
        <div>
          <p class="eyebrow">Self-hosted crypto engineering · since {site.foundedYear}</p>
          <h1 class="mt-4 max-w-2xl text-4xl font-semibold tracking-tight text-text sm:text-[3.4rem] sm:leading-[1.05]">
            We build crypto software and keep it running in production.
          </h1>
          <p class="mt-6 max-w-xl text-lg leading-relaxed text-muted">
            Bots, payments, trading tools, and node infrastructure — built by the engineers behind a
            real open-source blockchain ecosystem. You keep the keys; we do the engineering.
          </p>
          <div class="mt-8 flex flex-wrap items-center gap-3">
            <ContactModal client:load />
            <a href="#services" class="btn-secondary">See what we build</a>
          </div>
        </div>
        <div class="hidden justify-center lg:flex">
          <ForgeGraphic />
        </div>
      </div>

      <dl class="mt-14 grid grid-cols-3 gap-4 border-t border-border pt-8 sm:gap-8">
        <div>
          <dt class="font-mono text-[0.68rem] uppercase tracking-[0.18em] text-muted">Years in production</dt>
          <dd class="mt-1 text-3xl font-semibold tracking-tight text-text">{yearsRunning}+</dd>
        </div>
        <div>
          <dt class="font-mono text-[0.68rem] uppercase tracking-[0.18em] text-muted">Open-source repos</dt>
          <dd class="mt-1 text-3xl font-semibold tracking-tight text-text">{repoCount}+</dd>
        </div>
        <div>
          <dt class="font-mono text-[0.68rem] uppercase tracking-[0.18em] text-muted">Client keys we hold</dt>
          <dd class="mt-1 text-3xl font-semibold tracking-tight text-accent">0</dd>
        </div>
      </dl>
    </div>
  </section>

  <section class="section-light border-b border-border">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
      <p class="eyebrow">Why teams pick us</p>
      <h2 class="mt-3 text-2xl font-semibold tracking-tight text-text sm:text-3xl">
        Everything we sell, we also run ourselves
      </h2>
      <p class="mt-4 max-w-3xl text-muted">
        Our background is not theoretical: we are the builders behind ADAMANT — a blockchain,
        messenger, and wallet ecosystem that has been online for a decade. That changes how we
        write software for you.
      </p>

      <div class="mt-10 grid gap-6 md:grid-cols-3">
        <div class="card card-marked">
          <p class="font-mono text-xs text-accent">01</p>
          <h3 class="mt-3 font-semibold text-text">Operators, not tourists</h3>
          <p class="mt-2 text-sm leading-relaxed text-muted">
            We run our own nodes, wallets, bots, and explorers. When we design your system, we
            already know how it fails at 3 a.m. — because we carry the pager for ours.
          </p>
        </div>
        <div class="card card-marked">
          <p class="font-mono text-xs text-accent">02</p>
          <h3 class="mt-3 font-semibold text-text">Self-hosted by default</h3>
          <p class="mt-2 text-sm leading-relaxed text-muted">
            Your keys, your servers, your data. We design systems where custody stays with you, and
            we can walk away without taking anything hostage.
          </p>
        </div>
        <div class="card card-marked">
          <p class="font-mono text-xs text-accent">03</p>
          <h3 class="mt-3 font-semibold text-text">No hype clauses</h3>
          <p class="mt-2 text-sm leading-relaxed text-muted">
            No profit promises, no fake volume, no token launches. We build tools and
            infrastructure — measurable engineering with clear boundaries.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section id="services" class="section-light border-b border-border">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
      <p class="eyebrow">Services</p>
      <h2 class="mt-3 text-2xl font-semibold tracking-tight text-text sm:text-3xl">What we forge</h2>
      <p class="mt-4 max-w-3xl text-muted">
        Six directions, one discipline: software your team controls, deployed on infrastructure you
        own, maintained for years.
      </p>
      <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          services.map((service) => (
            <a href={`/${service.slug}`} class="card card-link group block no-underline">
              <div class="flex h-11 w-11 items-center justify-center rounded-lg border border-border bg-bg text-accent transition group-hover:border-ember/50">
                <ServiceIcon slug={service.slug} size={24} />
              </div>
              <h3 class="mt-4 font-semibold text-text">{service.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-muted">{service.shortDescription}</p>
              <span class="mt-4 inline-flex items-center gap-1.5 font-mono text-xs font-medium uppercase tracking-widest text-accent">
                Learn more <span aria-hidden="true" class="transition group-hover:translate-x-0.5">→</span>
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-light border-b border-border">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
      <p class="eyebrow">Process</p>
      <h2 class="mt-3 text-2xl font-semibold tracking-tight text-text sm:text-3xl">
        How an engagement runs
      </h2>
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          process.map((item, index) => (
            <div class="relative">
              <div class="flex items-center gap-3">
                <span class="font-mono text-2xl font-semibold text-accent">{item.step}</span>
                {index < process.length - 1 && (
                  <span class="hidden h-px flex-1 bg-border lg:block" aria-hidden="true" />
                )}
              </div>
              <h3 class="mt-3 font-semibold text-text">{item.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-muted">{item.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-dark border-b border-dark-border">
    <div class="grid-texture-dark">
      <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
        <p class="eyebrow">Proof of work</p>
        <h2 class="mt-3 text-2xl font-semibold tracking-tight sm:text-3xl">
          Open-source work and production infrastructure
        </h2>
        <p class="mt-4 max-w-3xl">
          A decade of continuous development, open since {site.foundedYear}. Production blockchain
          infrastructure you can inspect commit by commit on GitHub — no slide-deck Web3.
        </p>
        <div class="mt-10">
          <RepoCarousel client:load repos={reposData} />
        </div>
      </div>
    </div>
  </section>

  <section class="section-light border-b border-border">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
      <p class="eyebrow">Engineering notes</p>
      <h2 class="mt-3 text-2xl font-semibold tracking-tight text-text">From the workshop</h2>
      <p class="mt-3 max-w-2xl text-muted">
        Technical articles, release notes, and engineering updates — coming in Phase 3.
      </p>
    </div>
  </section>

  <section class="section-light">
    <div class="mx-auto max-w-6xl px-4 py-20 sm:px-6">
      <div class="card card-marked mx-auto max-w-3xl p-8 text-center sm:p-12">
        <p class="eyebrow">Start a project</p>
        <h2 class="mt-3 text-2xl font-semibold tracking-tight text-text sm:text-3xl">
          Tell us what you want to automate
        </h2>
        <p class="mx-auto mt-4 max-w-xl text-muted">
          Describe the workflow in plain words — we respond with an engineering take, not a sales
          script. No hype, no custody, no guaranteed-profit fairy tales.
        </p>
        <div class="mt-8 flex justify-center">
          <ContactModal client:load />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
