---
import HomePage from '../../components/HomePage.astro';
import { getLocaleFromPathParam, getNonDefaultLocales } from '../../i18n';

export function getStaticPaths() {
  return getNonDefaultLocales().map((locale) => ({
    params: { locale: locale.path },
  }));
}

const locale = getLocaleFromPathParam(Astro.params.locale!);
---

<HomePage locale={locale} />
