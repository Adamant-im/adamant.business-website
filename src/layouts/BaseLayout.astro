---
import '../styles/global.css';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import SeoHead from '../components/SeoHead.astro';
import { getLocaleConfig, type LocaleId } from '../i18n';

interface Props {
  title: string;
  description: string;
  locale: LocaleId;
  canonicalPath?: string;
  ogType?: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  pageType?: 'WebPage' | 'CollectionPage';
  prevPath?: string;
  nextPath?: string;
}

const { title, description, locale, canonicalPath, ogType, ogImage, jsonLd, pageType, prevPath, nextPath } = Astro.props;
const localeConfig = getLocaleConfig(locale);
const htmlLang = localeConfig.codes[0];
---

<!doctype html>
<html lang={htmlLang} dir={localeConfig.dir}>
  <head>
    <SeoHead
      title={title}
      description={description}
      locale={locale}
      canonicalPath={canonicalPath}
      ogType={ogType}
      ogImage={ogImage}
      jsonLd={jsonLd}
      pageType={pageType}
      prevPath={prevPath}
      nextPath={nextPath}
    />
  </head>
  <body class="min-h-screen">
    <Header locale={locale} />
    <main>
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
